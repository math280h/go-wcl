# Warcraft Logs API credentials.
# Create a client at https://www.warcraftlogs.com/api/clients/
# Copy this file to .env and fill in the values.
#
# These are only required for development of this library to introspect the schema
# (tools/introspect) and by the examples. End users pass credentials at
# runtime via the SDK options.

WCL_CLIENT_ID=
WCL_CLIENT_SECRET=
